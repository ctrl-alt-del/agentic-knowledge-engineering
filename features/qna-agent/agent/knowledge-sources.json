{
  "priority": "dir-first-then-json",
  "directory": "agent/knowledge/",
  "index": "agent/knowledge-index.json",
  "sources": [
    {
      "name": "正向文档",
      "type": "local-dir",
      "path": "agent/knowledge/forward/",
      "format": "markdown",
      "enabled": true,
      "description": "文档正向知识：培训手册、用户指南、API文档、FAQ"
    },
    {
      "name": "代码知识",
      "type": "local-dir",
      "path": "agent/knowledge/reverse/",
      "format": "markdown",
      "enabled": true,
      "description": "代码负向知识：仓库分析、debug经验、AST"
    },
    {
      "name": "胶囊日志",
      "type": "local-dir",
      "path": "agent/knowledge/capsule/",
      "format": "markdown",
      "enabled": true,
      "description": "胶囊知识：日志分析、成功/失败模式"
    }
  ],
  "search": {
    "max_chunks": 5,
    "max_chunk_bytes": 4000,
    "min_score": 0.01
  }
}
