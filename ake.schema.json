{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["llm", "skills"],
  "properties": {
    "llm": {
      "type": "object",
      "required": ["provider", "apiKey", "baseURL", "model"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["openai-compatible", "anthropic"],
          "description": "LLM API 类型"
        },
        "apiKey": {
          "type": "string",
          "description": "API 密钥（建议使用环境变量 ${VAR_NAME}）"
        },
        "baseURL": {
          "type": "string",
          "description": "API 基础 URL"
        },
        "model": {
          "type": "string",
          "description": "模型名称/ID"
        },
        "options": {
          "type": "object",
          "properties": {
            "temperature": { "type": "number", "minimum": 0, "maximum": 2 },
            "maxTokens": { "type": "integer", "minimum": 1, "maximum": 131072 },
            "stream": { "type": "boolean" }
          }
        }
      }
    },
    "skills": {
      "type": "object",
      "required": ["paths", "autoload"],
      "properties": {
        "paths": {
          "type": "array",
          "items": { "type": "string" },
          "description": "技能文件搜索路径"
        },
        "autoload": {
          "type": "array",
          "items": { "type": "string" },
          "description": "启动时自动加载的技能名称列表"
        }
      }
    }
  }
}
